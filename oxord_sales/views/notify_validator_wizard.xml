<odoo>
    <record id="view_sale_order_notify_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.notify.wizard.form</field>
        <field name="model">sale.order.notify.wizard</field>
        <field name="arch" type="xml">
            <form string="Notify Validator">
                <group>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="user_id"/>                
                </group>
                <footer>
                    <button string="Notify"
                            type="object"
                            name="action_notify_validator"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_notify_validator_wizard" model="ir.actions.act_window">
        <field name="name">Notify Validator</field>
        <field name="res_model">sale.order.notify.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sale_order_notify_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>