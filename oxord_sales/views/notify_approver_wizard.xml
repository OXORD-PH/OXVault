<odoo>
    <record id="view_notify_approver_wizard_form" model="ir.ui.view">
        <field name="name">notify.approver.wizard.form</field>
        <field name="model">sale.order.notify.approver.wizard</field>
        <field name="arch" type="xml">
            <form string="Notify Approver">
                <group>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="user_id"/>
                </group>
                <footer>
                    <button name="action_notify_approver"
                            type="object"
                            string="Notify"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_notify_approver_wizard" model="ir.actions.act_window">
        <field name="name">Notify Approver</field>
        <field name="res_model">sale.order.notify.approver.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_notify_approver_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>