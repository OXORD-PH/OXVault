<odoo>
    <!-- Customer Approval Wizard Form -->
    <record id="view_sale_order_customer_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.customer.wizard.form</field>
        <field name="model">sale.order.customer.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Approval">
                <group string="Customer Details">
                    <field name="customer_id"/>
                    <field name="customer_date" readonly="1"/>
                    <field name="signature_customer" widget="signature"/>
                </group>

                <footer>
                    <button name="action_confirm_customer"
                            type="object"
                            string="Approve &amp; Continue"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open Customer Approval Wizard -->
    <record id="action_customer_approval_wizard" model="ir.actions.act_window">
        <field name="name">Customer Approval</field>
        <field name="res_model">sale.order.customer.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sale_order_customer_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>